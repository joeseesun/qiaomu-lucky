# Server
HOST=127.0.0.1
PORT=3158
LUCKY_PUBLIC_BASE_URL=http://127.0.0.1:3158

# Required: change these before running a public deployment.
LUCKY_ADMIN_PASSWORD=change-me-to-a-long-admin-password
LUCKY_SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Optional storage paths. Defaults are relative to the project directory.
# LUCKY_DATA_DIR=./data
# LUCKY_DATA_FILE=./data/lottery-data.json
# LUCKY_STATIC_DIR=./dist
# LUCKY_SECRETS_FILE=./data/runtime-secrets.json

# Optional Umami analytics. Leave empty to disable tracking.
# VITE_UMAMI_SCRIPT_URL=https://umami.example.com/script.js
# VITE_UMAMI_WEBSITE_ID=
# VITE_UMAMI_DOMAINS=
